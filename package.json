{
  "name": "symphony-beads",
  "version": "0.1.0",
  "type": "module",
  "description": "Symphony implementation for Beads issue tracker",
  "bin": {
    "symphony": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts start",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check src/",
    "lint:fix": "bunx @biomejs/biome check --fix src/",
    "fmt": "bunx @biomejs/biome format --write src/",
    "fmt:check": "bunx @biomejs/biome format src/",
    "typecheck": "bun x tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun test"
  },
  "dependencies": {
    "@opentui/core": "^0.1.88",
    "@opentui/react": "^0.1.88",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  }
}